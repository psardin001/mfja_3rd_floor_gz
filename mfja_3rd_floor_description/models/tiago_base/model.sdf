<?xml version="1.0"?>
<sdf version="1.9">
  <model name="tiago_base">
    <self_collide>false</self_collide>
    <allow_auto_disable>false</allow_auto_disable>

    <link name="base_link">
      <inertial>
        <pose>0 0 0.22 0 0 0</pose>
        <mass>22.0</mass>
        <inertia>
          <ixx>0.65</ixx>
          <iyy>0.65</iyy>
          <izz>0.70</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="base_link_visual">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.20</radius>
            <length>0.20</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <collision name="base_link_collision">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.22</radius>
            <length>0.20</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <link name="base_footprint">
      <pose relative_to="base_footprint_joint">0 0 0 0 0 0</pose>
    </link>

    <link name="left_wheel_link">
      <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.003</ixx>
          <iyy>0.005</iyy>
          <izz>0.003</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.5</mu>
              <mu2>2.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="right_wheel_link">
      <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.003</ixx>
          <iyy>0.005</iyy>
          <izz>0.003</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.5</mu>
              <mu2>2.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="caster_front_link">
      <pose relative_to="caster_front_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <iyy>0.0002</iyy>
          <izz>0.0002</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="caster_front_visual">
        <geometry>
          <sphere>
            <radius>0.03</radius>
          </sphere>
        </geometry>
      </visual>
      <collision name="caster_front_collision">
        <geometry>
          <sphere>
            <radius>0.03</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="caster_rear_link">
      <pose relative_to="caster_rear_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <iyy>0.0002</iyy>
          <izz>0.0002</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="caster_rear_visual">
        <geometry>
          <sphere>
            <radius>0.03</radius>
          </sphere>
        </geometry>
      </visual>
      <collision name="caster_rear_collision">
        <geometry>
          <sphere>
            <radius>0.03</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name="torso_fixed_link">
      <pose relative_to="base_to_torso_fixed">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0.02435 -0.00464 0.159 0 0 0</pose>
        <mass>14.0136</mass>
        <inertia>
          <ixx>0.383411</ixx>
          <iyy>0.405773</iyy>
          <izz>0.076998</izz>
          <ixy>0.000364</ixy>
          <ixz>-0.024389</ixz>
          <iyz>-0.000782</iyz>
        </inertia>
      </inertial>
      <visual name="torso_fixed_link_visual">
        <geometry>
          <mesh>
            <uri>model://tiago/meshes/torso/torso_fix.stl</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="torso_fixed_link_collision">
        <geometry>
          <mesh>
            <uri>model://tiago/meshes/torso/torso_fix.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <link name="torso_lift_link">
      <pose relative_to="torso_lift_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0.04361 -0.00116 -0.17334 0 0 0</pose>
        <mass>6.93198</mass>
        <inertia>
          <ixx>0.24487</ixx>
          <iyy>0.249269</iyy>
          <izz>0.090395</izz>
          <ixy>-0.001456</ixy>
          <ixz>-0.009742</ixz>
          <iyz>0.008281</iyz>
        </inertia>
      </inertial>
      <visual name="torso_lift_link_visual">
        <geometry>
          <mesh>
            <uri>model://tiago/meshes/torso/torso_lift_with_arm.stl</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="torso_lift_link_collision">
        <geometry>
          <mesh>
            <uri>model://tiago/meshes/torso/torso_lift_with_arm.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name="base_footprint_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_footprint</child>
      <pose relative_to="base_link">0 0 0 0 0 0</pose>
    </joint>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <pose relative_to="base_link">0 0.23 0.10 -1.57079632679 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <pose relative_to="base_link">0 -0.23 0.10 -1.57079632679 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>40</effort>
          <velocity>30</velocity>
        </limit>
        <dynamics>
          <damping>0.2</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="caster_front_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_front_link</child>
      <pose relative_to="base_link">0.18 0 0.03 0 0 0</pose>
    </joint>

    <joint name="caster_rear_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_rear_link</child>
      <pose relative_to="base_link">-0.18 0 0.03 0 0 0</pose>
    </joint>

    <joint name="base_to_torso_fixed" type="fixed">
      <parent>base_link</parent>
      <child>torso_fixed_link</child>
      <pose relative_to="base_link">-0.062 0 0.193 0 0 0</pose>
    </joint>

    <joint name="torso_lift_joint" type="prismatic">
      <parent>torso_fixed_link</parent>
      <child>torso_lift_link</child>
      <pose relative_to="torso_fixed_link">0 0 0.597 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0.0</lower>
          <upper>0.35</upper>
          <effort>2000.0</effort>
          <velocity>0.07</velocity>
        </limit>
        <dynamics>
          <damping>1500.0</damping>
          <friction>10.0</friction>
        </dynamics>
      </axis>
    </joint>

    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.46</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <wheel_torque>120</wheel_torque>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publisher_frequency>50</odom_publisher_frequency>
    </plugin>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>torso_lift_joint</joint_name>
    </plugin>

    <plugin
      filename="gz-sim-joint-trajectory-controller-system"
      name="gz::sim::systems::JointTrajectoryController">
      <joint_name>torso_lift_joint</joint_name>
      <initial_position>0.05</initial_position>
      <position_p_gain>800.0</position_p_gain>
      <position_i_gain>0.8</position_i_gain>
      <position_d_gain>120.0</position_d_gain>
      <position_i_min>-2.0</position_i_min>
      <position_i_max>2.0</position_i_max>
      <position_cmd_min>-2500.0</position_cmd_min>
      <position_cmd_max>2500.0</position_cmd_max>
    </plugin>
  </model>
</sdf>
