    <joint name="world_joint" type="fixed">
      <parent>world</parent>
      <child>base_link</child>
    </joint>

    <joint name="joint_1" type="revolute">
      <parent>base_link</parent>
      <child>link_1</child>
      <pose relative_to="base_link">0 0 0.375 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265359</lower>
          <upper>3.14159265359</upper>
          <effort>220.0</effort>
          <velocity>7.59218224618</velocity>
        </limit>
        <dynamics>
          <damping>0.7</damping>
          <friction>0.08</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="joint_2" type="revolute">
      <parent>link_1</parent>
      <child>link_2</child>
      <pose relative_to="link_1">0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-2.22529479629</lower>
          <upper>2.22529479629</upper>
          <effort>140.0</effort>
          <velocity>6.71951762018</velocity>
        </limit>
        <dynamics>
          <damping>0.7</damping>
          <friction>0.08</friction>
        </dynamics>
